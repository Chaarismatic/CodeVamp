{
    "name": "codevamp-monorepo",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev:api": "npm run start:dev -w api",
        "dev:web": "npm run dev -w web",
        "build:api": "npm run build -w api",
        "build:web": "npm run build -w web",
        "start:api": "npm run start:prod -w api",
        "install:all": "npm install",
        "infra:up": "docker-compose up -d",
        "infra:down": "docker-compose down"
    },
    "dependencies": {
        "@nestjs/cli": "^11.0.16",
        "typescript": "^5.9.3"
    }
}